# Coinbase/CDP credentials
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
CHIMERA_CDP_BASE_URL=https://api.coinbase.com/agentkit/v1
CHIMERA_DAILY_BUDGET_USD=500.00
CHIMERA_QUEUE_MAX_RETRIES=2
CHIMERA_REPLAY_COOLDOWN_SECONDS=300
CHIMERA_REPLAY_MAX_PER_TASK_PER_DAY=3
