# DB/Cache
POSTGRES_URL=jdbc:postgresql://localhost:5432/chimera
POSTGRES_USER=chimera
POSTGRES_PASSWORD=chimera
REDIS_URL=redis://localhost:6379

# API auth (format: key:tenant:role1,role2;key2:tenant2:role1)
CHIMERA_API_KEYS=dev-tenant-alpha-key:tenant-alpha:operator,reviewer,viewer;dev-tenant-beta-key:tenant-beta:operator,reviewer,viewer
CHIMERA_JWT_HS256_SECRET=
CHIMERA_JWT_ISSUER=
CHIMERA_JWT_AUDIENCE=
CHIMERA_JWT_JWKS_PATH=
CHIMERA_JWT_JWKS_URL=
CHIMERA_JWT_JWKS_REFRESH_SECONDS=60
CHIMERA_JWT_JWKS_HTTP_TIMEOUT_MS=2000
CHIMERA_WRITE_RATE_LIMIT_MAX_REQUESTS=30
CHIMERA_WRITE_RATE_LIMIT_WINDOW_SECONDS=60
